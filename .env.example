# ==========================================================
# Knowledge Retrieval System (KRS)
# Example Environment Configuration
#
# Copy this file to .env and update the values if needed.
# ==========================================================

# ==========================================================
# Repository Configuration
# ==========================================================

REPOSITORY_NAME=fastapi
REPOSITORY_FOLDER=fastapi-master
GITHUB_REPOSITORY=https://github.com/fastapi/fastapi
DEFAULT_BRANCH=master

# ==========================================================
# Project Settings
# ==========================================================

PROJECT_NAME=Knowledge Retrieval System
PROJECT_VERSION=1.0.0
DEBUG=False

# ==========================================================
# MCP Server
# ==========================================================

MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp
MCP_TRANSPORT=http

# ==========================================================
# ChromaDB
# ==========================================================

CHROMA_DB_PATH=chroma_db

# ==========================================================
# Chroma Collections
# ==========================================================

FILES_COLLECTION=Files_Collection_v1
CLASSES_COLLECTION=Classes_Collection_v1
METHODS_COLLECTION=Methods_Collection_v1
FUNCTIONS_COLLECTION=Functions_Collection_v1
CODE_BLOCK_COLLECTION=Code_Block_Collection_v1

# ==========================================================
# Embedding Model
# ==========================================================

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ==========================================================
# Chunking
# ==========================================================

CHUNK_MAX_TOKENS=500
CHUNK_MIN_TOKENS=80

# ==========================================================
# Reranker
# ==========================================================

RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ==========================================================
# Retrieval
# ==========================================================

DEFAULT_ALPHA=0.8
DEFAULT_TOP_K=5
MAX_RESULTS=20

# ==========================================================
# Logging
# ==========================================================

LOG_LEVEL=INFO
LOG_FILE=logs/krs.log